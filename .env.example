# ─── ARTO 환경 변수 설정 예시 ───────────────────────────────
# 이 파일을 .env 로 복사 후 값을 수정하세요.
# cp .env.example .env

# LM Studio / OpenAI-compatible AI 백엔드
LM_STUDIO_API_URL=http://192.168.1.100:1234/v1
LM_STUDIO_MODEL=qwen/qwen3.5-9b

# OWASP ZAP REST API 주소 (Docker 기본값: localhost:8080)
ZAP_BASE_URL=http://localhost:8080

# ARTO 서버 바인딩 (기본: 0.0.0.0:8001)
ARTO_HOST=0.0.0.0
ARTO_PORT=8001
